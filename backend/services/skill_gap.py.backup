"""Skill gap analysis service."""

import os
import json
from typing import List, Dict, Any
from groq import Groq

# Job role → required skills mapping
JOB_ROLES: Dict[str, List[str]] = {
    "Data Scientist": [
        "Python", "Machine Learning", "Statistics", "Data Visualization",
        "SQL", "Deep Learning", "NLP", "Pandas", "NumPy", "Scikit-learn", "TensorFlow"
    ],
    "Web Developer": [
        "HTML", "CSS", "JavaScript", "React", "Node.js", "REST APIs",
        "Git", "SQL", "TypeScript", "Responsive Design"
    ],
    "Full Stack Developer": [
        "HTML", "CSS", "JavaScript", "React", "Node.js", "REST APIs",
        "SQL", "MongoDB", "Git", "TypeScript", "Docker"
    ],
    "Android Developer": [
        "Java", "Kotlin", "Android SDK", "Firebase", "REST APIs",
        "Git", "Material Design", "SQLite"
    ],
    "Cloud Engineer": [
        "AWS", "Azure", "GCP", "Docker", "Kubernetes", "Terraform",
        "Linux", "Python", "CI/CD", "Networking"
    ],
    "DevOps Engineer": [
        "Linux", "Docker", "Kubernetes", "CI/CD", "Git", "Ansible",
        "Terraform", "Python", "Monitoring", "AWS"
    ],
    "Cybersecurity Analyst": [
        "Networking", "Linux", "Python", "Ethical Hacking", "SIEM",
        "Cryptography", "Incident Response", "Firewalls", "Vulnerability Assessment"
    ],
    "ML Engineer": [
        "Python", "Machine Learning", "Deep Learning", "TensorFlow",
        "PyTorch", "Docker", "REST APIs", "SQL", "Scikit-learn", "MLOps"
    ],
    # More roles... (abbreviated for brevity)
}

# Course recommendations per skill
COURSE_RECOMMENDATIONS: Dict[str, Dict[str, str]] = {
    "Python": {"name": "Python for Everybody", "platform": "Coursera", "url": "https://coursera.org/specializations/python"},
    "Machine Learning": {"name": "Machine Learning Specialization", "platform": "Coursera", "url": "https://coursera.org/specializations/machine-learning-introduction"},
    # ... all other courses
}

# Internship recommendations per skill
INTERNSHIP_RECOMMENDATIONS: Dict[str, Dict[str, str]] = {
    "Python": {"name": "Python Development Intern", "platform": "Internshala", "url": "https://internshala.com/internships/python-development-internship"},
    # ... all other internships
}

def normalize_skill(skill: str) -> str:
    """Normalize skill name for matching."""
    return skill.strip().lower().replace("-", " ").replace("_", " ")

def get_recommendations(missing_skills: List[str]) -> List[Dict[str, Any]]:
    """Get course and internship recommendations for missing skills."""
    recommendations = []
    for skill in missing_skills:
        if skill in COURSE_RECOMMENDATIONS:
            course = COURSE_RECOMMENDATIONS[skill]
            recommendations.append({
                "skill": skill,
                "type": "course",
                "name": course["name"],
                "platform": course["platform"],
                "url": course["url"],
                "image": "https://images.unsplash.com/photo-1524178232363-5491e663f1f8?w=300&h=200&fit=crop",
                "duration": "4-6 weeks",
                "rating": "4.7",
                "provider_logo": f"https://via.placeholder.com/40x40/8B5CF6/FFFFFF?text={course['platform'][0]}"
            })
        if skill in INTERNSHIP_RECOMMENDATIONS:
            internship = INTERNSHIP_RECOMMENDATIONS[skill]
            recommendations.append({
                "skill": skill,
                "type": "internship",
                "name": internship["name"],
                "platform": internship["platform"],
                "url": internship["url"],
                "image": "https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=300&h=200&fit=crop",
                "duration": "3-6 months",
                "rating": "4.5",
                "provider_logo": f"https://via.placeholder.com/40x40/F59E0B/FFFFFF?text={internship['platform'][0]}"
            })
    return recommendations[:12]

def search_recommendations(q: str) -> Dict[str, Any]:
    """Search courses and internships by skill/query."""
    q = q.lower().strip()
    results = []
    # Search courses
    for skill, info in COURSE_RECOMMENDATIONS.items():
        if q in skill.lower() or q in info['name'].lower() or q in info['platform'].lower():
            results.append({
                **info,
                'skill': skill,
                'type': 'course',
                'image': "https://images.unsplash.com/photo-1524178232363-5491e663f1f8?w=300&h=200&fit=crop",
                'duration': '4-6 weeks',
                'rating': '4.7',
                'provider_logo': f"https://via.placeholder.com/40x40/8B5CF6/FFFFFF?text={info['platform'][0]}"
            })
    # Search internships
    for skill, info in INTERNSHIP_RECOMMENDATIONS.items():
        if q in skill.lower() or q in info['name'].lower() or q in info['platform'].lower():
            results.append({
                **info,
                'skill': skill,
                'type': 'internship',
                'image': "https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=300&h=200&fit=crop",
                'duration': '3-6 months',
                'rating': '4.5',
                'provider_logo': f"https://via.placeholder.com/40x40/F59E0B/FFFFFF?text={info['platform'][0]}"
            })
    return {
        'recommendations': results[:20],
        'total': len(results),
        'query': q
    }

def analyze_skill_gap(user_skills: List[str], target_role: str) -> Dict[str, Any]:
    if target_role not in JOB_ROLES:
        return {"error": f"Role '{target_role}' not found. Available: {list(JOB_ROLES.keys())}"}

    required = JOB_ROLES[target_role]
    user_normalized = {normalize_skill(s) for s in user_skills}
    required_normalized = {normalize_skill(r) for r in required}

    matched = [r for r in required if normalize_skill(r) in user_normalized]
    missing = [r for r in required if normalize_skill(r) not in user_normalized]

    match_rate = round(len(matched) / len(required) * 100, 1) if required else 0
    skill_gap_index = round(1 - len(matched) / len(required), 4) if required else 0

    recommendations = get_recommendations(missing)

    radar_data = []
    for skill in required:
        radar_data.append({
            "skill": skill,
            "has": 1 if normalize_skill(skill) in user_normalized else 0,
        })

    return {
        "target_role": target_role,
        "required_skills": required,
        "matched_skills": matched,
        "missing_skills": missing,
        "match_rate": match_rate,
        "skill_gap_index": skill_gap_index,
        "recommendations": recommendations,
        "radar_data": radar_data,
        "total_required": len(required),
        "total_matched": len(matched),
        "total_missing": len(missing),
    }

def get_available_roles() -> List[str]:
    return list(JOB_ROLES.keys())

